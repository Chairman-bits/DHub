<Window x:Class="ShortcutList.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DHub"
        Width="1320"
        Height="780"
        MinWidth="1120"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        SourceInitialized="Window_SourceInitialized">
    <DockPanel Background="{StaticResource WindowBackgroundBrush}" LastChildFill="True">

        <Border DockPanel.Dock="Top"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource ToolbarButtonStyle}" Click="AddButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="20" Foreground="#16A34A" Text="＋"/>
                        <TextBlock Margin="8,0,0,0" Text="追加"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" Style="{StaticResource ToolbarButtonStyle}" Click="EditButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✎" FontSize="18" Foreground="#2F80ED"/>
                        <TextBlock Margin="8,0,0,0" Text="編集"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" Style="{StaticResource DangerButtonStyle}" Click="DeleteButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" FontSize="18" Foreground="#E5484D"/>
                        <TextBlock Margin="8,0,0,0" Text="削除"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="6" Style="{StaticResource ToolbarButtonStyle}" Click="BackupButton_Click" ToolTip="ショートカット一覧をJSONファイルとして保存します">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬇" FontSize="16" Foreground="#64748B"/>
                        <TextBlock Margin="8,0,0,0" Text="保存"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="8" Style="{StaticResource ToolbarButtonStyle}" Click="ColumnSettingsButton_Click" ToolTip="一覧の列表示を切り替えます">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▦" FontSize="16" Foreground="#64748B"/>
                        <TextBlock Margin="8,0,0,0" Text="列"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="10" Style="{StaticResource ToolbarButtonStyle}" Click="SettingsButton_Click" ToolTip="設定とデータの入出力">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙" FontSize="16" Foreground="#64748B"/>
                        <TextBlock Margin="8,0,0,0" Text="設定"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="12" Style="{StaticResource ToolbarButtonStyle}" Click="CheckLinksButton_Click" ToolTip="存在しないファイルやフォルダを確認します">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" FontSize="16" Foreground="#64748B"/>
                        <TextBlock Margin="8,0,0,0" Text="確認"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="14" Style="{StaticResource ToolbarButtonStyle}" Click="OpenFolderButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📂" FontSize="16"/>
                        <TextBlock Margin="8,0,0,0" Text="場所を開く"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="16" Style="{StaticResource ToolbarButtonStyle}" Click="RunButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" FontSize="18" Foreground="#22C55E"/>
                        <TextBlock Margin="8,0,0,0" Text="開く"/>
                    </StackPanel>
                </Button>

                <TextBox x:Name="SearchTextBox"
                         Grid.Column="18"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchTextBox_TextChanged"
                         ToolTip="スペース区切りでAND検索できます"/>

                <ComboBox x:Name="FilterComboBox"
                          Grid.Column="20"
                          VerticalContentAlignment="Center"
                          SelectionChanged="FilterComboBox_SelectionChanged"/>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom"
                   Background="{StaticResource PanelBackgroundBrush}"
                   BorderBrush="{StaticResource BorderBrush}"
                   BorderThickness="0,1,0,0"
                   Padding="6,2">
            <StatusBarItem>
                <TextBlock x:Name="CountTextBlock" Foreground="{StaticResource SecondaryTextBrush}" Text="0 個のショートカット"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="SortStatusTextBlock" Foreground="{StaticResource SecondaryTextBrush}" Text="並び順: 手動"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="HealthStatusTextBlock" Foreground="{StaticResource SecondaryTextBrush}" Text="未検出 0 件"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="VersionTextBlock" Foreground="{StaticResource SecondaryTextBrush}" Text="v1.0.0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Ctrl+Space クイック検索 / Ctrl+F 検索 / Ctrl+N 追加 / Enterで開く"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="12">
            <ListView x:Name="ShortcutListView"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      MouseDoubleClick="ShortcutListView_MouseDoubleClick"
                      SelectionChanged="ShortcutListView_SelectionChanged"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.Resources>
                    <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
                        <EventSetter Event="Click" Handler="GridViewColumnHeader_Click"/>
                    </Style>
                </ListView.Resources>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="44">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="20" Text="{Binding IconText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="色" Width="48">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="16"
                                            Height="16"
                                            CornerRadius="8"
                                            Background="{Binding TagColor}"
                                            HorizontalAlignment="Center"
                                            ToolTip="{Binding GroupDisplay}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn x:Name="NameColumn" Header="名前" Width="240" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn x:Name="PathColumn" Header="パス" Width="460" DisplayMemberBinding="{Binding TargetPath}"/>
                        <GridViewColumn x:Name="ArgumentsColumn" Header="引数" Width="150" DisplayMemberBinding="{Binding Arguments}"/>
                        <GridViewColumn x:Name="GroupColumn" Header="タグ" Width="120" DisplayMemberBinding="{Binding GroupDisplay}"/>
                        <GridViewColumn x:Name="LaunchCountColumn" Header="起動回数" Width="90" DisplayMemberBinding="{Binding LaunchCount}"/>
                        <GridViewColumn x:Name="LastLaunchColumn" Header="最終起動" Width="150" DisplayMemberBinding="{Binding LastLaunchedDisplay}"/>
                        <GridViewColumn x:Name="CreatedAtColumn" Header="作成日" Width="150" DisplayMemberBinding="{Binding CreatedAt}"/>
                        <GridViewColumn x:Name="UpdatedAtColumn" Header="更新日" Width="150" DisplayMemberBinding="{Binding UpdatedAt}"/>
                        <GridViewColumn x:Name="StatusColumn" Header="状態" Width="90" DisplayMemberBinding="{Binding StatusText}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </DockPanel>
</Window>
